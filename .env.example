# =============================================================
# Moocha 环境变量配置模板
# 复制此文件为 .env 并填入实际值
#
# Moocha environment variable template
# Copy this file to .env and fill in your actual values
# =============================================================

# AI 服务 API Key（云端模型必填，本地 Ollama 可留空或填占位符）
# AI service API key (required for cloud models, optional for local Ollama)
MOOCHA_API_KEY=

# 日志级别：error | warn | info | debug | trace（默认 info）
# Log level: error | warn | info | debug | trace (default: info)
RUST_LOG=info
