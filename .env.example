# Moocha Configuration Example
# Copy this file to .env and fill in your configuration

# AI API Key (required)
# OpenAI: https://platform.openai.com/api-keys
# Ollama: leave empty or use any value
MOOCHA_API_KEY=your_api_key_here

# API Base URL (optional)
# OpenAI: https://api.openai.com/v1
# Ollama: http://localhost:11434/v1
MOOCHA_BASE_URL=https://api.openai.com/v1

# Model Name (optional)
# OpenAI: gpt-3.5-turbo, gpt-4, gpt-4o
# Ollama: llama2, mistral, codellama
MOOCHA_MODEL_NAME=gpt-3.5-turbo

# Provider Type (optional)
# Values: openai, ollama, custom
MOOCHA_PROVIDER_TYPE=openai
